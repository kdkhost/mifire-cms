<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# ── Block sensitive files ─────────────────────────────────────
<FilesMatch "^\.env|\.git|composer\.json|composer\.lock|package\.json|package-lock\.json|artisan$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
